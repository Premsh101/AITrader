# AITrader environment variables
# Copy this file to .env and fill in the real values before running.
# Never commit the real .env file to source control.

# PostgreSQL connection string (used by SQLAlchemy and Alembic)
DATABASE_URL=postgresql://trader:trader_pass@db:5432/aitrader

# --- API security -----------------------------------------------------------
# Shared secret required (as the X-API-Key header) on all mutating endpoints:
# POST /toggle-mode, PATCH /config, POST /order.  If unset, those endpoints
# return 503 (fail closed).  Generate with: openssl rand -hex 32
AITRADER_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Comma-separated list of origins allowed by CORS (the dashboard URL).
ALLOWED_ORIGINS=http://localhost:8006

# The dashboard build embeds this key and sends it on mutating requests.
# Must equal AITRADER_API_KEY.  NOTE: NEXT_PUBLIC_* values are visible to
# anyone who can load the dashboard, so keep the dashboard itself private
# (loopback binding / reverse-proxy auth).
NEXT_PUBLIC_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- Trading loop -----------------------------------------------------------
# Seconds between trading cycles (default 300).
TRADING_LOOP_INTERVAL=300
# Seconds to cache Yahoo Finance daily-bar data (default 900).
FETCH_TTL_SECONDS=900
# Set to 1 to bypass the NSE market-hours gate (testing only).
TRADING_ALWAYS_ON=0
# Rupees of capital allocated per portfolio slot; order quantity is
# floor(TRADE_CAPITAL_PER_SLOT / price), minimum 1 share.
TRADE_CAPITAL_PER_SLOT=10000

# --- Risk overlays (Phase 1 safety net) --------------------------------------
# Notional account size for equity/death-protocol tracking (₹).
BASE_CAPITAL=50000
# Hard stop-loss as a positive fraction (0.05 = exit at -5%).
RISK_STOP_LOSS_PCT=0.05
# Force-exit any position held this many bars.
RISK_MAX_HOLD_BARS=20
# Profit ladder: once peak gain >= trigger, protect at breakeven / lock level.
RISK_BREAKEVEN_TRIGGER=0.05
RISK_TRAIL_TRIGGER=0.10
RISK_TRAIL_LOCK=0.08
# Death protocol: equity below (1 - drawdown) x peak equity flattens & halts.
RISK_DEATH_DRAWDOWN=0.25
# Block new entries when India VIX jumps more than this in a day.
RISK_VIX_SPIKE_PCT=0.15
# Regime filter: new entries only while NIFTY > its N-day SMA (1=on).
RISK_REGIME_FILTER=1
RISK_REGIME_SMA_BARS=200
# Minimum 20-day average turnover (₹) for a stock to be tradeable.
RISK_MIN_TURNOVER=50000000
# Volatility-scaled sizing: slot capital scaled by TARGET_ATR_PCT/ATR%,
# capped at 1x, floored at MIN_SIZE_SCALE.
RISK_TARGET_ATR_PCT=0.02
RISK_MIN_SIZE_SCALE=0.25

# --- Shoonya / Finvasia broker credentials -----------------------------------
SHOONYA_USER=YOUR_USER_ID
SHOONYA_PASSWORD=YOUR_PASSWORD
SHOONYA_TOTP_KEY=YOUR_BASE32_TOTP_SECRET
SHOONYA_VENDOR_CODE=YOUR_VENDOR_CODE
SHOONYA_API_SECRET=YOUR_API_SECRET
SHOONYA_IMEI=YOUR_REGISTERED_IMEI
